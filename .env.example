# Copy this file to .env and fill in your values
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/traami?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
GOOGLE_API_KEY=your_google_maps_api_key
PORT=5000
NODE_ENV=development

# Email (Gmail) — needed for verification + password reset emails
# Use a Gmail App Password (not your normal Gmail password)
# Go to: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# Your live domain (used in email links)
BASE_URL=https://yourdomain.com
